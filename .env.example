NEXT_PUBLIC_SANITY_PROJECT_ID=your-project-id
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2025-04-01
NEXT_PUBLIC_SANITY_STUDIO_BASE_PATH=/studio
NEXT_PUBLIC_SANITY_PREVIEW_URL=http://127.0.0.1:3000
NEXT_PUBLIC_SANITY_STUDIO_URL=http://127.0.0.1:3333/studio

SANITY_PROJECT_ID=your-project-id
SANITY_DATASET=production
SANITY_API_READ_TOKEN=
SANITY_API_WRITE_TOKEN=
SANITY_REVALIDATE_SECRET=

# Ragent（嵌入聊天/管理后台 API）
# 须与 Spring 的 server.port + server.servlet.context-path 拼成「无前缀 API 根」
# 例：port=9090、context-path=/api/ragent →
# NEXT_PUBLIC_RAGENT_API_BASE_URL=http://127.0.0.1:9090/api/ragent
# 不设时默认请求 https://ragent.nageoffer.com
#
# 开发时可设为 true 以跳过真实登录（生产勿用）；想真登录时请设为 false 或删除该项
# NEXT_PUBLIC_RAGENT_BYPASS_AUTH=false
#
# 设为 true 时：已登录访问 /login 也不会被立刻跳到 /chat，便于本地调试登录页（用毕请关）
# NEXT_PUBLIC_RAGENT_ALLOW_LOGIN_PAGE=true
