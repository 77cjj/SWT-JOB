# 复制为 .env 后填入真实值
# 本地: ./dev.sh 启动后端时会自动加载
# 服务器: ./server.sh 启动后端时会自动加载

BAILIAN_API_KEY=your-bailian-api-key
# Google OAuth（后端校验 idToken，与前端 NEXT_PUBLIC_GOOGLE_CLIENT_ID 相同）
# GOOGLE_CLIENT_ID=xxxx.apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=GOCSPX-xxxx
# ECS 无法直连 Google 时（常见于国内机房），配置 Vercel 代理：
# GOOGLE_TOKENINFO_PROXY_URL=https://swtjob.vercel.app/api/auth/google-tokeninfo
# Apple Sign In
# APPLE_CLIENT_ID=与 NEXT_PUBLIC_APPLE_CLIENT_ID 相同
# APPLE_VERIFY_PROXY_URL=https://swtjob.vercel.app/api/auth/apple-verify
# 微信开放平台网站应用
# WECHAT_APP_ID=wxXXXXXXXX
# WECHAT_APP_SECRET=xxxxxxxx
# 企业微信 · 站点留言（后端 /public/site-inquiry 推送到群机器人，勿提交 key 到 Git）
# SITE_INQUIRY_WEWORK_WEBHOOK=https://qyapi.weixin.qq.com/cgi-bin/webhook/send?key=YOUR_KEY
# SITE_INQUIRY_WEBHOOK_SECRET=随机长字符串（与 Vercel 同名变量一致，可选）

# 服务器 ./server.sh 可选（4GB 升级后建议删掉旧的小内存 JVM 行，留空则自动 -Xmx1536m）
# LOW_MEM_MODE=auto
# SKIP_ROCKETMQ=auto
# JAVA_MEM_OPTS=
# BACKEND_PORT=9090

# 管理员（勿提交真实密码到 Git）
# ADMIN_PASSWORD=          # 运行 scripts/set-admin-password.sh 改数据库 admin 密码
# DEV_ADMIN_USERNAME=Admin
# DEV_ADMIN_PASSWORD=      # 可选 dev-admin 备用登录；留空则禁用
# NEW_USER_FREE_CHAT_QUOTA=3
