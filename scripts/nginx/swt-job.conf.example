# SWT-JOB 后端 API 反向代理示例
# 1. 复制到 Nginx 配置目录并修改 server_name
#    sudo cp scripts/nginx/swt-job.conf.example /etc/nginx/conf.d/swt-job.conf
# 2. 编辑域名后执行
#    ./server.sh nginx reload

upstream swt_backend {
    server 127.0.0.1:9090;
    keepalive 32;
}

server {
    listen 80;
    # 改成你的 API 域名，例如 api.example.com
    server_name api.example.com;

    client_max_body_size 100m;

    location /api/ragent/ {
        proxy_pass http://swt_backend/api/ragent/;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header Connection "";

        # SSE / 流式聊天
        proxy_buffering off;
        proxy_cache off;
        proxy_read_timeout 3600s;
        proxy_send_timeout 3600s;
    }

    location = /health {
        proxy_pass http://swt_backend/api/ragent/actuator/health;
        access_log off;
    }
}

# HTTPS 示例（若已用 certbot 申请证书，certbot 会自动追加 ssl 配置）
# server {
#     listen 443 ssl http2;
#     server_name api.example.com;
#     ...
# }
