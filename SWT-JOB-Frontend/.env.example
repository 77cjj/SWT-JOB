NEXT_PUBLIC_SANITY_PROJECT_ID=your-project-id
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2025-04-01
NEXT_PUBLIC_SANITY_STUDIO_BASE_PATH=/studio
NEXT_PUBLIC_SANITY_PREVIEW_URL=https://app.example.com
NEXT_PUBLIC_SANITY_STUDIO_URL=https://app.example.com/studio

SANITY_PROJECT_ID=your-project-id
SANITY_DATASET=production
SANITY_API_READ_TOKEN=
SANITY_API_WRITE_TOKEN=
SANITY_REVALIDATE_SECRET=

# Ragent（嵌入聊天/管理后台 API）
# 须与 Spring 的 server.port + server.servlet.context-path 拼成「无前缀 API 根」
# 例：port=9090、context-path=/api/ragent →
# NEXT_PUBLIC_RAGENT_API_BASE_URL=https://api.example.com/api/ragent
# 生产环境必须设置，未设置会在构建/运行时直接报错
#
# 开发时可设为 true 以跳过真实登录（生产环境会被强制关闭）
# NEXT_PUBLIC_RAGENT_BYPASS_AUTH=false
#
# 设为 true 时：已登录访问 /login 不会立即跳转；仅建议本地调试时使用
# NEXT_PUBLIC_RAGENT_ALLOW_LOGIN_PAGE=true

# Google 登录（OAuth 2.0 Web Client ID，须与站点域名一致；授权来源需加你的前端域名）
# 前端：
# NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
# 后端（Spring application.yaml / 环境变量，与前端 Client ID 相同）：
# GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
#
# 配置步骤简述：
# 1. Google Cloud Console → APIs & Services → Credentials → Create OAuth client ID (Web)
# 2. Authorized JavaScript origins 填生产/预览域名（如 https://your-domain.com）
# 3. 将 Client ID 同时写入前端 NEXT_PUBLIC_GOOGLE_CLIENT_ID 与后端 GOOGLE_CLIENT_ID
# 4. 未配置时登录页会显示「Google 登录未配置」，密码登录不受影响

# 悬浮客服 · 留言推送到微信（PushPlus: https://www.pushplus.plus/）
# SITE_INQUIRY_PUSHPLUS_TOKEN=your-pushplus-token
# 或通用 Webhook（JSON body）
# SITE_INQUIRY_WEBHOOK_URL=https://your-webhook.example.com/inquiry
# 页面上展示的微信号提示（可选）
# NEXT_PUBLIC_SITE_WECHAT_HINT=也可直接加微信：your_wechat_id
