NEXT_PUBLIC_SANITY_PROJECT_ID=your-project-id
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2025-04-01
NEXT_PUBLIC_SANITY_STUDIO_BASE_PATH=/studio
NEXT_PUBLIC_SANITY_PREVIEW_URL=https://app.example.com
NEXT_PUBLIC_SANITY_STUDIO_URL=https://app.example.com/studio

SANITY_PROJECT_ID=your-project-id
SANITY_DATASET=production
SANITY_API_READ_TOKEN=
SANITY_API_WRITE_TOKEN=
SANITY_REVALIDATE_SECRET=

# Ragent（嵌入聊天/管理后台 API）
# 须与 Spring 的 server.port + server.servlet.context-path 拼成「无前缀 API 根」
# 例：port=9090、context-path=/api/ragent →
# NEXT_PUBLIC_RAGENT_API_BASE_URL=https://api.example.com/api/ragent
# 生产环境必须设置，未设置会在构建/运行时直接报错
#
# 开发时可设为 true 以跳过真实登录（生产环境会被强制关闭）
# NEXT_PUBLIC_RAGENT_BYPASS_AUTH=false
#
# 设为 true 时：已登录访问 /login 不会立即跳转；仅建议本地调试时使用
# NEXT_PUBLIC_RAGENT_ALLOW_LOGIN_PAGE=true

# Google 登录（与 Google Cloud Web Client ID 一致）
# NEXT_PUBLIC_GOOGLE_CLIENT_ID=xxxx.apps.googleusercontent.com
# 设为 1 时在登录 UI 显示 Google Console 配置长提示（仅开发排查用）
# NEXT_PUBLIC_AUTH_DEBUG=1
# 后端 ECS（非 Vercel）若无法直连 Google，在服务器 .env 增加：
# GOOGLE_TOKENINFO_PROXY_URL=https://swtjob.vercel.app/api/auth/google-tokeninfo

# 悬浮客服 · 留言推送到微信（推荐 webhook）
# SITE_INQUIRY_WEBHOOK_URL=https://swtjob.vercel.app/api/ragent/auth/site-inquiry-webhook
# SITE_INQUIRY_WEBHOOK_SECRET=与服务器 .env 中 SITE_INQUIRY_WEBHOOK_SECRET 相同（建议配置）
# 页面上展示的微信号提示（可选）
# NEXT_PUBLIC_SITE_WECHAT_HINT=也可直接加微信：your_wechat_id

# Stripe（交易市集 · 见 docs/STRIPE_SETUP.md）
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# MARKETPLACE_STORE_PATH=/tmp/swt-marketplace.json
